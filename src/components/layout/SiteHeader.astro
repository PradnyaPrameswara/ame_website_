---
import { navigation } from "../../data/content";
---

<header class="site-header" data-site-header>
  <div class="page-container page-container--wide site-header__inner">
    <a class="brand" href="#top" aria-label="AME Creative Studio, home">AME</a>
    <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="mobile-menu" data-menu-toggle>
      <span class="sr-only">Open navigation menu</span><span></span><span></span>
    </button>
    <div class="mobile-menu" id="mobile-menu" aria-hidden="true" data-mobile-menu>
      <nav aria-label="Main navigation">
        {navigation.slice(0, 3).map((item, index) => <a href={item.href} data-menu-link><span>0{index + 1}</span>{item.label.replace(",", "")}</a>)}
      </nav>
      <div class="mobile-menu__foot"><span>Business enquiries</span><a href="mailto:studio@team-abcs.com">studio@team-abcs.com</a></div>
    </div>
  </div>
</header>

<style>
  .site-header { position: fixed; inset: 0 0 auto; z-index: 100; pointer-events: none; padding-top: 1.1rem; }
  .site-header__inner { display: flex; justify-content: space-between; align-items: start; }
  .brand { color: var(--accent); font: 850 clamp(3.6rem, 8vw, 7.2rem)/.62 var(--font-display); letter-spacing: -.1em; pointer-events: auto; }
  .menu-toggle { display: grid; gap: .45rem; width: 3.5rem; padding-top: .25rem; pointer-events: auto; }
  .menu-toggle span:not(.sr-only) { width: 100%; height: 2px; background: var(--ink); transition: transform .35s var(--ease-out); }
  .menu-toggle[aria-expanded="true"] span:nth-child(2) { transform: translateY(.28rem) rotate(45deg); }
  .menu-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-.28rem) rotate(-45deg); }
  .mobile-menu { position: fixed; inset: 0; z-index: -1; display: grid; align-content: space-between; padding: 9rem var(--page-gutter) 1.5rem; color: var(--white); background: var(--ink); opacity: 0; visibility: hidden; transform: translateY(-100%); transition: transform .55s var(--ease-out), opacity .3s, visibility .55s; pointer-events: auto; }
  .mobile-menu.is-open { opacity: 1; visibility: visible; transform: translateY(0); }
  .mobile-menu nav { display: grid; }
  .mobile-menu nav a { display: grid; grid-template-columns: 2rem 1fr; align-items: baseline; padding: .4rem 0; border-bottom: 1px solid #fff4; font: 700 clamp(2.8rem, 8vw, 7rem)/.88 var(--font-primary); letter-spacing: -.075em; text-transform: uppercase; }
  .mobile-menu nav span, .mobile-menu__foot { font: 500 .65rem/1.2 var(--font-primary); letter-spacing: .06em; text-transform: uppercase; }
  .mobile-menu__foot { display: flex; justify-content: space-between; gap: 1rem; }
  @media (min-width: 64rem) {
    .site-header { padding-top: 1.35rem; pointer-events: none; }
    .mobile-menu { padding-top: 12rem; padding-bottom: 2rem; }
    .brand, .menu-toggle { display: none; }
  }
</style>
