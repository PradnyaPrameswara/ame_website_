---
import AnimatedLink from "../ui/AnimatedLink.astro";
import { capabilities } from "../../data/content";
---

<section class="capabilities" aria-labelledby="capabilities-title" data-capabilities>
  <div class="capabilities__sticky page-container page-container--wide">
    <div class="capabilities__language">
      <p>We work in</p>
      <h2 id="capabilities-title">craft</h2>
      <p>We speak</p>
    </div>
    <div class="capabilities__viewport">
      <div>{capabilities.map((word, index) => <span class:list={{ "is-active": index === 0 }} data-capability-word>{word}</span>)}</div>
    </div>
    <div class="capabilities__support">
      <p>Handwork and precision. Natural materials and practical use. Our language is tactile, warm, and made for daily life.</p>
      <AnimatedLink href="#services" label="Explore AME" />
    </div>
  </div>
</section>

<style>
  .capabilities { position: relative; height: calc(3 * 82svh); padding: 0; background: var(--white); }
  .capabilities__sticky { position: sticky; top: 0; display: grid; grid-template-columns: 1fr 3fr; grid-template-rows: auto 1fr auto; gap: 1.5rem 3rem; height: 100svh; align-items: center; overflow: hidden; padding-block: 6vh; background: var(--white); }
  .capabilities__language { align-self: start; }
  .capabilities__language p { font-size: clamp(1rem, 1.6vw, 1.5rem); }
  .capabilities__language h2 { color: var(--accent); font: 850 clamp(3.6rem, 8vw, 8rem)/.8 var(--font-display); letter-spacing: -.08em; text-transform: uppercase; }
  .capabilities__viewport { grid-column: 1 / 3; height: clamp(7rem, 16vw, 16rem); overflow: hidden; }
  .capabilities__viewport > div { position: relative; height: 100%; }
  .capabilities__viewport span { position: absolute; inset: 0; display: flex; align-items: center; color: var(--ink); font: 850 clamp(5.5rem, 15vw, 16rem)/.72 var(--font-display); letter-spacing: -.09em; text-transform: uppercase; white-space: nowrap; opacity: 0; visibility: hidden; }
  .capabilities__viewport span.is-active { opacity: 1; visibility: visible; }
  .capabilities__support { grid-column: 2; display: grid; grid-template-columns: 1fr auto; gap: 3rem; align-items: end; }
  .capabilities__support p { max-width: 38rem; font-size: clamp(1.25rem, 2.2vw, 2.35rem); line-height: 1.08; letter-spacing: -.045em; }

  @media (max-width: 63.99rem) {
    .capabilities { height: auto; padding-block: 7rem; }
    .capabilities__sticky { position: relative; top: auto; display: grid; grid-template-columns: 1fr; grid-template-rows: auto; height: auto; overflow: visible; padding: 0; }
    .capabilities__language h2 { font-size: clamp(3rem, 13vw, 7rem); }
    .capabilities__viewport { grid-column: 1; height: auto; overflow: visible; }
    .capabilities__viewport > div { display: grid; height: auto; }
    .capabilities__viewport span { position: relative; inset: auto; padding-block: .12em; border-bottom: 1px solid #17171725; font-size: clamp(4rem, 18vw, 9rem); white-space: normal; transform: none; opacity: 1 !important; visibility: visible !important; }
    .capabilities__support { grid-column: 1; grid-template-columns: 1fr; margin-top: 2rem; }
  }
</style>
