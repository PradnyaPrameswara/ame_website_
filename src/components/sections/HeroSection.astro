---
import AnimatedLink from "../ui/AnimatedLink.astro";
import HeroImageTrail from "./HeroImageTrail.astro";
import { navigation } from "../../data/content";
---

<header class="hero" id="about" aria-labelledby="hero-title" data-hero>
  <div class="page-container page-container--wide hero__inner">
    <div class="hero__brand">
      <a href="#top" class="hero__wordmark" aria-label="AME Creative Studio, home"><span data-hero-wordmark><span>AME</span></span></a>
      <div class="hero__brand-meta">
        <span class="hero__brand-label">AME</span>
        <span class="hero__studio-label">Creative Studio</span>
      </div>
    </div>

    <nav class="hero__navigation" aria-label="Primary navigation">
      {navigation.map((item) => <a href={item.href} data-nav-link>{item.label.replace(",", "")}</a>)}
    </nav>

    <h1 id="hero-title" class="hero__statement" data-hero-line>Furniture and objects shaped for rooms, rituals, and a life well lived.</h1>

    <p class="hero__supporting-copy" data-hero-copy>AME is an independent furniture and craft studio, making tactile pieces with thoughtful materials and enduring purpose.</p>

    <div class="hero__cta" data-hero-cta><AnimatedLink href="#beginning" label="About us" /></div>
  </div>
  <HeroImageTrail />
</header>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: 100svh;
    background: var(--white);
    padding-block: clamp(1.5rem, 3vw, 3rem);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    grid-template-rows: auto minmax(0, 1fr) auto;
    min-height: calc(100svh - (clamp(1.5rem, 3vw, 3rem) * 2));
    position: relative;
    z-index: 1;
    column-gap: clamp(2rem, 5vw, 7rem);
    row-gap: clamp(1rem, 2vw, 2rem);
  }

  .hero__brand {
    grid-column: 1;
    grid-row: 1;
    display: flex;
    flex-direction: column;
    align-self: start;
  }

  .hero__wordmark {
    display: block;
    width: fit-content;
    color: var(--accent);
    font: 800 clamp(8rem, 18vw, 20rem)/0.72 var(--font-primary);
    letter-spacing: -0.075em;
    text-transform: uppercase;
    margin-left: -0.05em;
  }

  .hero__wordmark > span {
    display: block;
  }

  .hero__brand-meta {
    display: flex;
    justify-content: space-between;
    width: min(100%, 20rem);
    margin-top: 1.25rem;
    font: 800 clamp(0.7rem, 0.95vw, 0.9rem)/1 var(--font-primary);
    text-transform: uppercase;
    color: var(--accent);
    letter-spacing: 0.08em;
  }

  .hero__navigation {
    grid-column: 2;
    grid-row: 1;
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1rem, 2.5vw, 2rem);
    justify-content: flex-start;
    align-self: start;
    padding-top: clamp(0.2rem, 0.8vw, 1rem);
  }

  .hero__navigation a {
    font: 700 clamp(1.15rem, 1.7vw, 2rem)/1 var(--font-primary);
    color: var(--ink);
    text-transform: none;
    letter-spacing: -0.03em;
    transition: opacity 0.2s;
    white-space: nowrap;
  }

  .hero__navigation a:hover {
    opacity: 0.6;
  }

  .hero__statement {
    grid-column: 2;
    grid-row: 2;
    align-self: center;
    justify-self: start;
    width: min(100%, 43rem);
    margin: 0;
    font: 700 clamp(2.4rem, 3.35vw, 4.25rem)/0.96 var(--font-primary);
    letter-spacing: -0.045em;
    color: var(--ink);
  }

  .hero__supporting-copy {
    grid-column: 1;
    grid-row: 3;
    align-self: end;
    width: min(100%, 25rem);
    font: 500 clamp(0.95rem, 1.1vw, 1.2rem)/1.2 var(--font-primary);
    color: var(--ink);
    margin: 0;
  }

  .hero__cta {
    grid-column: 2;
    grid-row: 3;
    justify-self: start;
    align-self: end;
  }

  .hero__cta :global(.animated-link) {
    color: var(--white);
    background: var(--ink);
    border-color: var(--ink);
    text-transform: uppercase;
    padding: 0.8rem 1.5rem;
  }

  @media (max-width: 63.99rem) {
    .hero {
      padding-block: 6rem 4rem;
    }

    .hero__inner {
      display: flex;
      flex-direction: column;
      gap: 2.5rem;
      min-height: auto;
    }

    .hero__brand {
      width: 100%;
    }

    .hero__wordmark {
      max-width: 100%;
      font-size: clamp(5.25rem, 15vw, 8rem);
    }

    .hero__brand-meta {
      width: min(100%, 20rem);
    }

    .hero__navigation {
      width: 100%;
    }

    .hero__statement {
      width: 100%;
      font-size: clamp(3rem, 7vw, 4.8rem);
    }

    .hero__supporting-copy {
      width: min(100%, 25rem);
    }
  }

  @media (min-width: 64rem) and (max-width: 79.99rem) {
    .hero__inner {
      column-gap: clamp(1.5rem, 3vw, 4rem);
    }

    .hero__navigation {
      gap: clamp(0.85rem, 1.8vw, 1.5rem);
    }

    .hero__statement {
      width: min(100%, 40rem);
    }
  }
</style>